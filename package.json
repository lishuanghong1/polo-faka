{
  "name": "polo-faka",
  "version": "0.1.0",
  "private": true,
  "description": "Polo Faka - AI 账号 / 卡密自动发货商城（仿 yidachuang.top）",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:api": "pnpm --filter @polo/api dev",
    "dev:web": "pnpm --filter @polo/web dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "db:up": "docker compose up -d mysql redis",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d mysql redis",
    "prisma:push": "pnpm --filter @polo/api exec prisma db push",
    "prisma:migrate": "pnpm --filter @polo/api exec prisma migrate dev",
    "prisma:generate": "pnpm --filter @polo/api exec prisma generate",
    "prisma:seed": "pnpm --filter @polo/api run seed"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma",
      "vue-demi"
    ]
  }
}
