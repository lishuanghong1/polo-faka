{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Polo Cockpit",
  "version": "0.1.0",
  "identifier": "com.polo.cockpit",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "beforeBuildCommand": "pnpm vite:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Polo Cockpit",
        "width": 900,
        "height": 720,
        "minWidth": 640,
        "minHeight": 560,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Polo Cockpit 桌面控制台",
    "longDescription": "面向 Cursor 账号库、用量监控、号池调度和本机状态管理的 Polo 桌面控制台。账号数据与 token 默认保存在本机。"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["polo-cockpit", "polo-tool"]
      }
    }
  }
}
