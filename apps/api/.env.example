NODE_ENV=development
PORT=4000
API_PREFIX=/api

DATABASE_URL="mysql://polo:polo_pwd@localhost:33060/polo_faka"
REDIS_URL="redis://localhost:63790"

# ⚠️ 生产环境必须改成 64 位以上随机串
JWT_SECRET=please_change_me_in_production_xxxxxxxxxxxx
JWT_EXPIRES_IN=7d

# 号池 token 加密密钥（与 JWT_SECRET 独立、长度 ≥ 32 字符；上线后不要再改）
POOL_ENCRYPTION_KEY=please_change_me_pool_key_xxxxxxxxxxxxxxxxxxxx

# 首个管理员账号（仅 seed 时使用一次；上线后请立即修改密码）
ADMIN_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123456

# 前台允许来源（多个逗号分隔；生产请精确配置）
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# 是否允许 /api/orders/:orderNo/mock-pay 走 mock 支付（仅开发用，生产必须 false）
ENABLE_MOCK_PAY=true

# 是否运行在反向代理后（决定要不要信任 X-Forwarded-For）
TRUST_PROXY=false

# 管理员 IP 白名单（强烈建议生产环境配置）
# 留空 = 不限制（仅依赖 JWT + ADMIN 角色）
# 逗号分隔，支持单 IP 和 CIDR。如：127.0.0.1,::1,1.2.3.4,192.168.0.0/16
ADMIN_IP_ALLOWLIST=

# 支付宝（也可以在 /admin/settings 后台配置；env 优先）
# ALIPAY_ENABLED=false
# ALIPAY_SANDBOX=true
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_SIGN_TYPE=RSA2
# ALIPAY_NOTIFY_BASE=https://your-domain.com
