// Polo Faka - Prisma Schema
// AI 账号 / 卡密自动发货商城

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===================== 用户 =====================

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  email     String?    @unique
  password  String
  nickname  String?
  avatar    String?
  balance   Decimal    @default(0) @db.Decimal(12, 2)
  points    Int        @default(0)
  inviteCode String?   @unique @db.VarChar(16)
  inviterId Int?
  inviteRewardedAt DateTime?
  role      UserRole   @default(USER)
  status    UserStatus @default(ACTIVE)
  lastLogin DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // VIP 体系：升级由累计充值驱动，永久有效（不会回落）
  totalRecharged Decimal   @default(0) @db.Decimal(12, 2)
  vipTier        VipTier   @default(NONE)
  vipUpgradedAt  DateTime?

  // 专属折扣：管理员可单独给某用户设置（0.5~1，0.9 = 9 折）。
  // null = 无专属折扣，走 VIP 体系。下单时取「专属折扣」与「VIP 折扣」中更优（更低）的一个。
  customDiscount Decimal?  @db.Decimal(5, 4)

  orders          Order[]
  balanceLogs     BalanceLog[]
  rechargeOrders  RechargeOrder[]
  pointLogs       PointLog[]
  inviter         User?      @relation("UserInvites", fields: [inviterId], references: [id], onDelete: SetNull)
  invitees        User[]     @relation("UserInvites")

  @@index([createdAt])
  @@index([vipTier])
  @@index([inviterId])
  @@map("users")
}

// ===================== VIP =====================

enum VipTier {
  NONE       // 普通用户
  GOLD       // 黄金会员
  DIAMOND    // 钻石会员
  SUPREME    // 超级无敌会员
}

/// VIP 等级配置：门槛、默认折扣、显示样式。
/// 表内固定 3 条 (GOLD/DIAMOND/SUPREME) + 隐含 NONE 不入表。
model VipConfig {
  id              Int      @id @default(autoincrement())
  tier            VipTier  @unique
  name            String   @db.VarChar(32)             // 显示名
  threshold       Decimal  @db.Decimal(12, 2)          // 累计充值达到此金额即升此级
  defaultDiscount Decimal  @db.Decimal(5, 4)           // 0.0001 ~ 1.0000，0.95 = 95 折
  color           String?  @db.VarChar(32)             // 显示色（hex 或 tailwind 类名）
  icon            String?  @db.VarChar(32)             // emoji 或 svg 标识
  benefits        Json?                                // ["优先发货","专属客服"]
  sort            Int      @default(0)                 // 显示顺序
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("vip_configs")
}

enum ProductSource {
  LOCAL
  FORGE
  FORGE_QUOTA  // Cursorforge 额度包
}

/// 商品级 VIP 折扣覆盖。同一个商品某个等级有配置则用此，否则回退到 VipConfig.defaultDiscount。
/// productKey: LOCAL 存 Product.id 字符串化，FORGE 存 ForgeProduct.typeKey
model ProductDiscount {
  id            Int           @id @default(autoincrement())
  productSource ProductSource
  productKey    String        @db.VarChar(64)
  tier          VipTier
  discount      Decimal       @db.Decimal(5, 4)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([productSource, productKey, tier], map: "uniq_product_discount")
  @@index([productSource, productKey])
  @@map("product_discounts")
}

enum BalanceLogType {
  RECHARGE   // 充值
  CONSUME    // 消费
  REFUND     // 退款
  ADJUST     // 管理员调整
  REWARD     // 奖励
}

model BalanceLog {
  id        Int            @id @default(autoincrement())
  userId    Int
  amount    Decimal        @db.Decimal(12, 2) // 正为收入，负为支出
  balance   Decimal        @db.Decimal(12, 2) // 操作后余额
  type      BalanceLogType
  note      String?
  refOrder  String?        // 关联订单号
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 数据库层幂等：同一订单同一类型流水只能有一条（MySQL 中多个 NULL 不冲突，
  // 因此 ADJUST 等无 refOrder 的流水不受影响）
  @@unique([refOrder, type], map: "uniq_balance_log_ref_type")
  @@index([userId, createdAt])
  @@map("balance_logs")
}

enum PointLogType {
  ORDER_REWARD   // 消费返积分
  INVITE_REWARD  // 邀请首单返积分
  ORDER_DEDUCT   // 积分支付扣减
  ORDER_REFUND   // 积分支付退款
  ADMIN_ADJUST   // 管理员调整
}

model PointLog {
  id        Int          @id @default(autoincrement())
  userId    Int
  amount    Int          // 正为收入，负为支出
  balance   Int          // 操作后积分余额
  type      PointLogType
  note      String?
  refOrder  String?      @db.VarChar(64)
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 同一订单、同一用户、同一积分动作只能记一次，保证 notify / 补发 / 重试幂等。
  // MySQL 中 refOrder = NULL 可重复，因此管理员调整不受影响。
  @@unique([refOrder, type, userId], map: "uniq_point_log_ref_type_user")
  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("point_logs")
}

// ===================== 账户充值 =====================

enum RechargeStatus {
  PENDING    // 待支付
  PAID       // 已到账（余额已增 + BalanceLog 已记）
  CANCELLED  // 用户/系统取消
  EXPIRED    // 超时未付款
  REFUNDED   // 已退款（admin 原路退）
}

/// 充值订单：用户先创建 PENDING → 走支付宝 → notify 回调时校验金额并入账。
/// 入账 = User.balance increment + BalanceLog(type=RECHARGE) + 订单状态置 PAID（同一事务）。
model RechargeOrder {
  id            Int            @id @default(autoincrement())
  orderNo       String         @unique @db.VarChar(64) // R 开头
  userId        Int            // 充值必须登录，禁止游客
  amount        Decimal        @db.Decimal(12, 2)
  status        RechargeStatus @default(PENDING)
  payMethod     PayMethod      @default(ALIPAY) // 当前只支持支付宝
  thirdTradeNo  String?        @db.VarChar(64)  // 支付宝 trade_no
  buyerLogonId  String?        @db.VarChar(128) // 脱敏存
  paidAt        DateTime?
  expireAt      DateTime       // 15 分钟过期
  refundAmount  Decimal?       @db.Decimal(12, 2)
  refundedAt    DateTime?
  refundReason  String?        @db.VarChar(500)
  ip            String?        @db.VarChar(64)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, expireAt])
  @@map("recharge_orders")
}

// ===================== 商品 =====================

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  icon      String?
  sort      Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

enum ProductStatus {
  DRAFT
  ON_SALE
  OFF_SHELF
}

enum DeliveryType {
  CARD_KEY      // 卡密自动发货
  POOL_QUOTA    // 号池额度包（push token 后查询）
  MANUAL        // 人工发货
  AIZHP         // Aizhp 渠道获取账号
}

model Product {
  id           Int           @id @default(autoincrement())
  categoryId   Int
  title        String
  subtitle     String?       // 短描述（卡片下方那一行）
  description  String?       @db.Text // 富文本/Markdown
  tags         Json?         // ["新品", "质保", "热榜"]
  cover        String?
  images       Json?         // ["url1", "url2"]
  basePrice    Decimal       @db.Decimal(12, 2) // 起售价，用于列表展示
  sales        Int           @default(0)
  sort         Int           @default(0)
  status       ProductStatus @default(ON_SALE)
  deliveryType DeliveryType  @default(CARD_KEY)
  warranty     String?       // 质保说明文本
  // 批量阶梯优惠：[{min:1,max:10,price:1.2}, ...]
  bulkPricing  Json?
  // 积分相关开关：在商品维度独立控制是否返积分 / 是否允许积分下单
  // pointsAwardEnabled = false 时本商品不产生消费返积分和邀请首单奖励
  // pointsPayEnabled   = false 时本商品禁用积分支付通道
  pointsAwardEnabled Boolean   @default(true)
  pointsPayEnabled   Boolean   @default(false)
  // 返积分倍率：null 走全局默认（10%）。范围 0.0001 ~ 1.0000，等价于 0.01% ~ 100%
  pointsAwardRate    Decimal?  @db.Decimal(5, 4)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  skus     Sku[]
  cardKeys CardKey[]
  orders   Order[]

  @@index([categoryId, status, sort])
  @@map("products")
}

// 商品规格（变体）
model Sku {
  id        Int      @id @default(autoincrement())
  productId Int
  name      String   // 例如：质保七天 / Pro红账单账号
  price     Decimal  @db.Decimal(12, 2)
  originalPrice Decimal? @db.Decimal(12, 2)
  stock     Int      @default(0)         // 物理库存（备用，实际以 CardKey 表为准）
  sales     Int      @default(0)
  sort      Int      @default(0)
  visible   Boolean  @default(true)
  attrs     Json?    // 自定义属性
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  cardKeys CardKey[]
  orders   Order[]

  @@index([productId, visible])
  @@map("skus")
}

// ===================== 卡密池 =====================

enum CardKeyStatus {
  AVAILABLE  // 可售
  LOCKED     // 锁定（下单中）
  SOLD       // 已出售
  EXPIRED    // 失效（如被原厂封号）
  REFUNDED   // 售后回退
}

model CardKey {
  id        Int           @id @default(autoincrement())
  productId Int
  skuId     Int
  content   String        @db.Text // 实际卡密内容（账号+密码+邮箱等）
  remark    String?       // 内部备注
  status    CardKeyStatus @default(AVAILABLE)
  soldAt    DateTime?
  // 一个订单可包含多张卡密（quantity > 1），故此处不能是 @unique，
  // 否则发货时给多张卡密写同一 orderNo 会触发唯一约束冲突导致整单发货失败。
  orderNo   String?
  expireAt  DateTime?     // 卡密自带的过期时间
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  product Product @relation(fields: [productId], references: [id])
  sku     Sku     @relation(fields: [skuId], references: [id])
  order   Order?  @relation(fields: [orderNo], references: [orderNo])

  @@index([skuId, status])
  @@index([orderNo])
  @@map("card_keys")
}

// ===================== 订单 =====================

enum OrderStatus {
  PENDING    // 待支付
  PAID       // 已支付（卡密分配中）
  DELIVERED  // 已发货
  REFUNDED   // 已退款
  CANCELLED  // 已取消
  EXPIRED    // 超时未付款
}

enum PayMethod {
  ALIPAY
  WECHAT
  BALANCE
  POINTS
  USDT
  MOCK
  REDEEM
}

model Order {
  id            Int         @id @default(autoincrement())
  orderNo       String      @unique // 业务订单号，对外展示
  userId        Int?        // 允许游客下单
  productId     Int
  skuId         Int
  productTitle  String      // 下单时快照
  skuName       String
  unitPrice     Decimal     @db.Decimal(12, 2)
  quantity      Int         @default(1)
  totalAmount   Decimal     @db.Decimal(12, 2)              // 原价合计（unitPrice × qty）
  discountAmount Decimal    @default(0) @db.Decimal(12, 2)  // VIP / 优惠券折扣金额（正数）
  payAmount     Decimal     @db.Decimal(12, 2) // 实付（totalAmount - discountAmount，可能再被余额抵扣）
  pointsUsed    Int         @default(0)
  payMethod     PayMethod
  vipTier       VipTier     @default(NONE)                  // 下单时用户等级快照
  status        OrderStatus @default(PENDING)
  contact       String?     // 联系方式（QQ/邮箱/手机）
  remark        String?
  thirdTradeNo  String?     // 第三方交易号（支付宝 trade_no 等）
  buyerLogonId  String?     @db.VarChar(128) // 支付宝买家（脱敏）
  ip            String?
  paidAt        DateTime?
  deliveredAt   DateTime?
  expireAt      DateTime    // 待支付订单超时时间
  refundAmount  Decimal?    @db.Decimal(12, 2)
  refundedAt    DateTime?
  refundReason  String?     @db.VarChar(500)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user     User?     @relation(fields: [userId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])
  sku      Sku       @relation(fields: [skuId], references: [id])
  cardKeys CardKey[]

  @@index([userId, createdAt])
  @@index([status, expireAt])
  @@map("orders")
}

// ===================== 公告 =====================

enum AnnouncementPopupMode {
  ALWAYS
  ONCE
  NONE
}

model Announcement {
  id        Int                   @id @default(autoincrement())
  title     String
  content   String                @db.Text // Markdown 或 富文本（前端会 sanitize）
  cover     String?
  popup     Boolean               @default(false)
  popupMode AnnouncementPopupMode @default(NONE)
  sort      Int                   @default(0)
  active    Boolean               @default(true)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([active, sort])
  @@map("announcements")
}

// ===================== 站点设置（KV 表） =====================

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  isPublic  Boolean  @default(false) // 是否允许未授权读取（前台展示用）
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ===================== 号池（高阶） =====================

enum PoolAccountType {
  CURSOR_PRO
  CURSOR_ULTRA
  CURSOR_TEAM
  CUSTOM
}

enum PoolAccountStatus {
  HEALTHY
  LOW_QUOTA
  EXHAUSTED
  BANNED
  UNKNOWN
}

// 内部账号池：管理员录入的 Cursor 等账号
model PoolAccount {
  id          Int               @id @default(autoincrement())
  label       String            // 内部标签
  type        PoolAccountType   @default(CURSOR_PRO)
  token       String            @db.Text // 加密存储建议在 service 层处理
  email       String?
  totalQuota  Decimal           @default(0) @db.Decimal(12, 4) // 总额度 ($)
  usedQuota   Decimal           @default(0) @db.Decimal(12, 4) // 已用 ($)
  status      PoolAccountStatus @default(UNKNOWN)
  lastCheckAt DateTime?
  note        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  grants PoolGrant[]

  @@map("pool_accounts")
}

// 用户领取的额度配额（额度包业务）
model PoolGrant {
  id           Int       @id @default(autoincrement())
  orderNo      String    @unique
  accountId    Int?
  userToken    String?   @db.Text // 用户的 Cursor Token（用于 Token 激活模式）
  quotaTotal   Decimal   @db.Decimal(12, 4) // 购买的额度 $
  quotaUsed    Decimal   @default(0) @db.Decimal(12, 4)
  validityDays Int       @default(30)
  startAt      DateTime?
  endAt        DateTime?
  active       Boolean   @default(true)
  lastCheckAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  account PoolAccount? @relation(fields: [accountId], references: [id])

  @@map("pool_grants")
}

// ===================== 反馈 =====================

model Feedback {
  id        Int      @id @default(autoincrement())
  type      String   @default("general") // general / bulk / complaint
  content   String   @db.Text
  contact   String?
  handled   Boolean  @default(false)
  reply     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("feedbacks")
}

// ===================== 兑换码 =====================

enum RedeemCodeStatus {
  ACTIVE
  DISABLED
  EXHAUSTED
  EXPIRED
}

/// 一码 → 一个 SKU；可设置最大使用次数（默认 1）。
/// 兑换时调用 OrdersService.markPaidAndDeliver 复用卡密发货逻辑。
model RedeemCode {
  id         Int              @id @default(autoincrement())
  code       String           @unique @db.VarChar(64)
  productId  Int
  skuId      Int
  /// 该码每次兑换出多少件卡密
  qtyPerUse  Int              @default(1)
  /// 最大使用次数；超过即为 EXHAUSTED
  maxUses    Int              @default(1)
  usedCount  Int              @default(0)
  expireAt   DateTime?
  note       String?          @db.VarChar(255)
  /// 同批生成的标记
  batchTag   String?          @db.VarChar(64)
  status     RedeemCodeStatus @default(ACTIVE)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  records RedeemRecord[]

  @@index([batchTag])
  @@index([status, expireAt])
  @@index([skuId])
  @@map("redeem_codes")
}

model RedeemRecord {
  id        Int       @id @default(autoincrement())
  codeId    Int
  code      RedeemCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  orderNo   String     @db.VarChar(64)
  userId    Int?
  contact   String?    @db.VarChar(64)
  ip        String?    @db.VarChar(64)
  userAgent String?    @db.VarChar(500)
  createdAt DateTime   @default(now())

  @@index([codeId])
  @@index([orderNo])
  @@map("redeem_records")
}

// ===================== Cursorforge 三方代理 =====================
//
// 通过 HMAC-SHA256 签名调用 https://apiforge.cursorforgeai.top
// 业务模型：
//   1. 管理员同步三方商品 → 写入 forge_products
//   2. 管理员对每款商品设售价 displayPrice（cny）
//   3. 管理员批量生成兑换码（余额型，面额 totalAmount）
//   4. 用户输入兑换码 → 选商品 → 按 displayPrice 扣 usedAmount
//   5. 后端用 forge-openapi 调三方下单 → 拿到 accounts 加密入库
//   6. 用户在 /forge-order/:orderNo 查看 email + token，并可在本页接验证码

/// 本地缓存的三方商品（通过 GET /openapi/v1/products 同步）
model ForgeProduct {
  typeKey           String   @id @db.VarChar(64)
  categoryKey       String   @db.VarChar(64)
  typeName          String   @db.VarChar(128)
  categoryName      String   @db.VarChar(128)
  price             Decimal  @db.Decimal(12, 2) // 三方普通用户价
  agentPrice        Decimal  @db.Decimal(12, 2) // 三方代理价（我方成本）
  stock             Int      @default(0)        // 三方库存快照
  warrantyHours    Int?
  emailCodeEnabled  Boolean  @default(false)    // 三方是否允许接验证码
  /// 我方设的对终端用户售价（CNY），从兑换码余额扣减
  displayPrice      Decimal  @db.Decimal(12, 2)
  /// 我方是否上架（前台是否展示）
  enabled           Boolean  @default(false)
  sort              Int      @default(0)
  // ── 自定义详情：留空则回退到三方原始数据 ─────────────
  // 积分相关开关：在商品维度独立控制是否返积分 / 是否允许积分下单
  pointsAwardEnabled Boolean  @default(true)
  pointsPayEnabled   Boolean  @default(true)
  // 返积分倍率：null 走全局默认（10%）。范围 0.0001 ~ 1.0000
  pointsAwardRate    Decimal? @db.Decimal(5, 4)
  /// 自定义商品名（覆盖三方 typeName）
  customName        String?  @db.VarChar(128)
  /// 自定义分类名（覆盖三方 categoryName）
  customCategoryName String? @db.VarChar(128)
  /// 卖点一句话（详情页副标题 / 列表卡片副标题）
  subtitle          String?  @db.VarChar(255)
  /// 封面图 URL
  coverImage        String?  @db.VarChar(512)
  /// 详细描述（支持基本 HTML / Markdown 文本，详情页渲染）
  description       String?  @db.Text
  /// 亮点列表（JSON 数组字符串，如 ["秒到账","30天质保"]）
  highlights        String?  @db.Text
  /// 购买须知 / 注意事项（详情页底部黄色提示框）
  notice            String?  @db.Text
  lastSyncAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orders ForgeOrder[]

  @@index([enabled, sort])
  @@map("forge_products")
}

enum ForgeRedeemStatus {
  ACTIVE
  DISABLED
  EXHAUSTED
  EXPIRED
}

/// Cursorforge 兑换码（余额型）
model ForgeRedeemCode {
  id           Int               @id @default(autoincrement())
  code         String            @unique @db.VarChar(64)
  totalAmount  Decimal           @db.Decimal(12, 2) // 面额
  usedAmount   Decimal           @default(0) @db.Decimal(12, 2)
  status       ForgeRedeemStatus @default(ACTIVE)
  expireAt     DateTime?
  batchTag     String?           @db.VarChar(64)
  note         String?           @db.VarChar(255)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  orders      ForgeOrder[]
  quotaOrders ForgeQuotaOrder[] @relation("QuotaOrderRedeemCode")

  @@index([batchTag])
  @@index([status, expireAt])
  @@map("forge_redeem_codes")
}

enum ForgeOrderStatus {
  PENDING       // 已下单，等待付款（ALIPAY 路径）
  PAID          // 已付款，准备调三方发货
  DELIVERED     // 已发货（accounts 入库）
  FAILED        // 失败（库存 / 上游错误 等）
  CANCELLED     // 用户/系统取消
  EXPIRED       // 超时未支付
  REFUNDED      // 已退款（admin 原路退）
}

enum ForgePaymentMethod {
  REDEEM        // 兑换码支付
  ALIPAY        // 支付宝
  BALANCE       // 账户余额
  POINTS        // 积分支付
}

/// Cursorforge 三方订单（兑换码 / 支付宝 触发下单，accounts 加密保存）
model ForgeOrder {
  id                Int                @id @default(autoincrement())
  orderNo           String             @unique @db.VarChar(64) // 我方订单号 & 三方 external_order_id
  userId            Int?               // 可空（访客下单）
  /// 仅 REDEEM 路径填，ALIPAY 路径为 null
  redeemCodeId      Int?
  paymentMethod     ForgePaymentMethod @default(REDEEM)

  typeKey           String             @db.VarChar(64)
  typeName          String             @db.VarChar(128)
  quantity          Int                @default(1)
  displayPrice      Decimal            @db.Decimal(12, 2) // 单价（售价）
  totalAmount       Decimal            @db.Decimal(12, 2) // 原价合计（displayPrice × quantity）
  discountAmount    Decimal            @default(0) @db.Decimal(12, 2) // VIP 折扣金额
  payAmount         Decimal?           @db.Decimal(12, 2) // 实付（totalAmount - discountAmount）
  pointsUsed        Int                @default(0)
  vipTier           VipTier            @default(NONE)     // 下单时用户等级快照

  /// 客户联系方式（QQ / 邮箱 / 手机），便于售后查单
  contact           String?            @db.VarChar(128)
  /// sha256(orderNo + salt)；三方要求脱敏标识
  customerRef       String             @db.VarChar(128)

  status            ForgeOrderStatus   @default(PENDING)

  /// 支付宝交易号（仅 ALIPAY 路径）
  thirdTradeNo      String?            @db.VarChar(64)
  /// 支付宝买家登录名（脱敏存，如 138****1234@qq.com）
  buyerLogonId      String?            @db.VarChar(128)
  paidAt            DateTime?
  /// 待支付订单超时时间（仅 ALIPAY 路径，超时变 EXPIRED）
  expireAt          DateTime?
  /// 退款金额（admin 发起原路退款时记录）
  refundAmount      Decimal?           @db.Decimal(12, 2)
  refundedAt        DateTime?
  refundReason      String?            @db.VarChar(500)

  upstreamOrderNo   String?            @db.VarChar(64)
  upstreamRequestId String?            @db.VarChar(64)
  upstreamAmount    Decimal?           @db.Decimal(12, 2)
  /// 三方返回 accounts 数组（加密 JSON）
  upstreamData      String?            @db.Text
  deliveredAt       DateTime?
  failReason        String?            @db.VarChar(500)
  ip                String?            @db.VarChar(64)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  redeemCode ForgeRedeemCode? @relation(fields: [redeemCodeId], references: [id])
  product    ForgeProduct?    @relation(fields: [typeKey], references: [typeKey])

  @@index([redeemCodeId])
  @@index([status, createdAt])
  @@index([status, expireAt])
  @@index([typeKey])
  @@index([userId, createdAt])
  @@map("forge_orders")
}

/// Cursorforge 额度包（quota-packages 同步 + 我方售价/上架配置）
model ForgeQuotaPackage {
  packageKey  String  @id @db.VarChar(64)
  name        String  @db.VarChar(128)           // 三方原始名（如 官方线路额度包10美金）
  quotaUsd    Decimal @db.Decimal(12, 2)         // 面值（美元）：核销时充进买家 Key 的额度
  lineKey     String  @db.VarChar(64)            // 绑定线路（买家无 Key 时按此线路建 Key）
  agentPrice  Decimal @db.Decimal(12, 2)         // 代理出库价（我方成本，CNY）
  retailPrice Decimal @db.Decimal(12, 2)         // 官方零售价（定价参考，CNY）
  /// 我方对终端用户的售价（CNY）
  displayPrice Decimal @db.Decimal(12, 2)
  /// 我方是否上架（前台是否展示）
  enabled     Boolean @default(false)
  sort        Int     @default(0)
  // 积分：商品维度控制返积分 / 积分支付
  pointsAwardEnabled Boolean  @default(true)
  pointsPayEnabled   Boolean  @default(true)
  pointsAwardRate    Decimal? @db.Decimal(5, 4)  // null 走全局默认 10%
  // ── 自定义详情：留空则回退到三方原始数据 ─────────
  customName  String? @db.VarChar(128)
  subtitle    String? @db.VarChar(255)
  coverImage  String? @db.VarChar(512)
  description String? @db.Text
  highlights  String? @db.Text                    // JSON 数组字符串
  notice      String? @db.Text
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders ForgeQuotaOrder[]

  @@index([enabled, sort])
  @@map("forge_quota_packages")
}

/// Cursorforge 额度包购码订单（交付物 = 兑换码，加密存 upstreamData）
model ForgeQuotaOrder {
  id            Int                @id @default(autoincrement())
  orderNo       String             @unique @db.VarChar(64) // 我方订单号（Q 前缀）& 三方 external_order_id
  userId        Int?               // 可空（访客下单）
  /// 仅 REDEEM 路径填（本站余额型兑换码）
  redeemCodeId  Int?
  paymentMethod ForgePaymentMethod @default(REDEEM)

  packageKey  String  @db.VarChar(64)
  packageName String  @db.VarChar(128)
  quotaUsd    Decimal @db.Decimal(12, 2)  // 面值快照（美元）
  lineKey     String  @db.VarChar(64)
  quantity    Int     @default(1)
  displayPrice   Decimal  @db.Decimal(12, 2) // 我方单价（售价快照）
  totalAmount    Decimal  @db.Decimal(12, 2) // 原价合计
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  payAmount      Decimal? @db.Decimal(12, 2) // 实付
  pointsUsed     Int      @default(0)
  vipTier        VipTier  @default(NONE)

  contact     String? @db.VarChar(128)
  /// sha256(orderNo + salt)；三方要求脱敏标识
  customerRef String  @db.VarChar(128)

  status ForgeOrderStatus @default(PENDING)

  thirdTradeNo String? @db.VarChar(64)
  buyerLogonId String? @db.VarChar(128)
  paidAt       DateTime?
  expireAt     DateTime?
  refundAmount Decimal? @db.Decimal(12, 2)
  refundedAt   DateTime?
  refundReason String?  @db.VarChar(500)

  upstreamOrderNo   String?  @db.VarChar(64)  // 三方 order_no（B 前缀）
  upstreamBatchNo   String?  @db.VarChar(64)  // 三方批次号（AQ 前缀）
  upstreamRequestId String?  @db.VarChar(64)
  upstreamAmount    Decimal? @db.Decimal(12, 2) // 三方实扣（我方成本）
  /// 三方返回 codes 数组（加密 JSON：code/redeem_url/status/used_at/voided_at/void_reason）
  upstreamData String? @db.Text
  /// 码状态统计（refreshCodes 时同步）
  usedCount     Int       @default(0)
  voidedCount   Int       @default(0)
  codesSyncedAt DateTime?

  deliveredAt DateTime?
  failReason  String? @db.VarChar(500)
  ip          String? @db.VarChar(64)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redeemCode ForgeRedeemCode?   @relation("QuotaOrderRedeemCode", fields: [redeemCodeId], references: [id])
  package    ForgeQuotaPackage? @relation(fields: [packageKey], references: [packageKey])

  @@index([redeemCodeId])
  @@index([status, createdAt])
  @@index([status, expireAt])
  @@index([packageKey])
  @@index([userId, createdAt])
  @@map("forge_quota_orders")
}

// ===================== 审计日志 =====================

/// 记录所有敏感/管理操作，便于事后追溯。
/// 不写入业务数据，只写"谁、什么时候、对什么对象、做了什么"
model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?     // 操作者用户 ID（系统操作为 null）
  actor     String?  @db.VarChar(64) // 显示用：admin / username / system / guest
  action    String   @db.VarChar(64) // 见 audit.constants.ts
  target    String?  @db.VarChar(128) // 目标资源：order:Pxxx / pool:1 / sku:3 / user:5
  detail    Json?    // 业务细节
  ip        String?  @db.VarChar(64)
  userAgent String?  @db.VarChar(500)
  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([target, createdAt])
  @@map("audit_logs")
}

// ===================== 仓库 =====================

/// 由外部系统（如 cursor-jb）推送进来的账号库存，admin 可在管理后台
/// 分配到具体 Product/SKU。分配后会同步创建一条 CardKey；售出时
/// orderNo / soldAt 会回填到这里，便于外部系统反查。
model WarehouseAccount {
  id          Int       @id @default(autoincrement())
  /// 外部系统的引用键，如 "cursor-jb:5"。同一 sourceRef 重复推送不会重复入库
  sourceRef   String?   @unique @db.VarChar(128)
  /// 账号内容（如 email----emailpwd----cursorpwd----token），SKU 内唯一
  content     String    @db.Text
  email       String?   @db.VarChar(255)
  remark      String?   @db.VarChar(500)
  /// 分配状态：PENDING (未分配) / ASSIGNED (已分配到商品) / SOLD (已售出)
  status      String    @default("PENDING") @db.VarChar(16)
  productId   Int?
  skuId       Int?
  cardKeyId   Int?      @unique
  assignedAt  DateTime?
  soldAt      DateTime?
  orderNo     String?   @db.VarChar(64)
  /// 售出后到点自动退款/通知的时间（soldAt + 退款延迟）；可后台手动改/清空
  refundAt        DateTime?
  /// 已推送企业微信退款提醒的时间（有值即已通知，避免重复推送）
  refundNotifiedAt DateTime?
  /// 退款备注（后台填，随企微提醒一起发出）
  refundNote      String?   @db.VarChar(500)
  /// 自动退款状态：NONE(未退) / DONE(已退成功) / FAILED(退款失败)
  refundStatus    String    @default("NONE") @db.VarChar(16)
  /// 退款成功时间
  refundedAt      DateTime?
  /// 退款金额（美元，来自 preview 预估）
  refundAmount    Float?
  /// 退款失败原因
  refundError     String?   @db.VarChar(500)
  /// 自动退款尝试次数（用于节流 + 上限）
  refundAttempts  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([skuId, status])
  @@index([status, refundAt, refundStatus])
  @@map("warehouse_accounts")
}

// ===================== 回收（退款申请） =====================

/// 用户在前台「回收」页提交的退款申请记录。
/// 提交时用账号微软邮箱给 Cursor 发退款邮件，并记录当前订阅类型；
/// 之后通过查 Cursor 订阅（free=成功 / pro 等=回收中）判断回收是否完成。
model RecycleRequest {
  id            Int       @id @default(autoincrement())
  email         String    @db.VarChar(255)
  invoiceNumber String    @db.VarChar(128)
  /// 关联订单号（账号售出时回填到仓库账号的 orderNo）
  orderNo       String?   @db.VarChar(64)
  /// 最近一次查到的订阅类型：free / pro / pro_plus / ultra ...
  plan          String?   @db.VarChar(32)
  /// 状态：PENDING(回收中) / SUCCESS(成功) / UNKNOWN(未知)
  status        String    @default("PENDING") @db.VarChar(16)
  /// 发信成功时的 messageId（排查用）
  mailMessageId String?   @db.VarChar(255)
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([orderNo])
  @@map("recycle_requests")
}

// ===================== 订阅号池（cursor-jb 合并） =====================

/// Cursor 订阅账号池：从 cursor-jb 合并进来的账号管理。
/// 凭据（cursor 密码 / 邮箱密码 / cursor token）AES-GCM 加密存储。
/// 售出联动仓库：以 warehouseRef 关联 warehouse_accounts.sourceRef。
model CursorSubAccount {
  id                   Int       @id @default(autoincrement())
  email                String    @unique @db.VarChar(255)
  /// Cursor 登录密码（加密，可空——token 导入的账号可能没有）
  passwordEnc          String?   @db.Text
  /// 邮箱密码（加密，收验证码用）
  emailPasswordEnc     String?   @db.Text
  /// WorkosCursorSessionToken 值 user_xxx::jwt（加密，查订阅 / 生成结账链接用）
  cursorTokenEnc       String?   @db.Text
  note                 String?   @db.VarChar(500)
  /// 本地跟踪状态：unsubscribed / subscribed / expired / unlisted
  status               String    @default("unsubscribed") @db.VarChar(16)
  /// Cursor 真实订阅类型（同步用量时写入）：free / pro / pro_plus / ultra / business ...
  membershipType       String?   @db.VarChar(32)
  /// 用量快照（同步时写入）：已用 / 上限 / 已用百分比
  planUsed             Float?
  planLimit            Float?
  planPercentUsed      Float?
  paidAt               DateTime?
  expiresAt            DateTime?
  subscriptionDays     Int       @default(30)
  /// 推送到仓库时用的 sourceRef（迁移账号沿用 cursor-jb:{oldId}，新账号 cursor-sub:{id}）
  warehouseRef         String?   @unique @db.VarChar(128)
  /// 最近一次同步 Cursor 订阅的时间
  lastSyncedAt         DateTime?
  /// 最近一次生成的订阅结账链接（checkout.stripe.com/c/pay/cs_live_...）
  lastCheckoutUrl      String?   @db.Text
  /// 结账链接生成时间（Stripe 会话有有效期，仅供参考）
  lastCheckoutAt       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
  @@index([expiresAt])
  @@map("cursor_sub_accounts")
}

/// 客户自助退款白名单：只有在此列表里的邮箱，前台输入邮箱才能触发自动退款。
/// 后台批量导入（email----...----token / 带标签格式），存 cursor token（加密）用于退款。
model RefundWhitelist {
  id             Int       @id @default(autoincrement())
  email          String    @unique @db.VarChar(255)
  /// 加密的 cursor token（user_xxx::JWT），退款链用
  cursorTokenEnc String    @db.Text
  note           String?   @db.VarChar(255)
  batchTag       String?   @db.VarChar(64)
  /// NONE(可退未退) / PROCESSING(退款中) / DONE(已退) / FAILED(失败)
  refundStatus   String    @default("NONE") @db.VarChar(16)
  refundedAt     DateTime?
  refundAmount   Float?
  refundError    String?   @db.VarChar(500)
  /// 客户前台申请时间 / IP
  appliedAt      DateTime?
  appliedIp      String?   @db.VarChar(64)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([refundStatus])
  @@index([batchTag])
  @@map("refund_whitelist")
}

/// 前台「凭 token 直接退款」的记录（不校验白名单，token 本身即凭证）。
/// 仅用于后台查看退款历史与结果；不落明文 token，只存掩码用于识别。
/// 付费账号需先支付手续费（Ultra ¥50，其它 ¥10）才办理退款，相关支付字段记录在此。
model TokenRefundLog {
  id              Int       @id @default(autoincrement())
  /// 退款账号邮箱（退款链解析 token 后回填，可能为空）
  email           String?   @db.VarChar(255)
  /// token 掩码（首尾片段），用于识别，不存完整明文
  tokenMask       String    @db.VarChar(80)
  /// 加密的完整 token：仅「需付费后退款」的场景暂存，退款完成后可清空
  cursorTokenEnc  String?   @db.Text
  /// NEED_PAY(待支付手续费) / PROCESSING(处理中) / DONE(已退) / FAILED(失败)
  status          String    @default("PROCESSING") @db.VarChar(16)
  membershipType  String?   @db.VarChar(32)
  refundAmount    Float?
  prevMembership  String?   @db.VarChar(32)
  finalMembership String?   @db.VarChar(32)
  refundError     String?   @db.VarChar(500)
  /// 退款手续费，单位元；为 null 表示无需付费
  feeAmount       Float?
  /// 手续费支付订单号（T 开头），支付宝对账用
  payOrderNo      String?   @unique @db.VarChar(64)
  /// NONE(无需支付) / UNPAID(待支付) / PAID(已支付)
  payStatus       String    @default("NONE") @db.VarChar(16)
  payTradeNo      String?   @db.VarChar(64)
  paidAt          DateTime?
  /// 前台提交时的 IP
  ip              String?   @db.VarChar(64)
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([payStatus])
  @@index([createdAt])
  @@map("token_refund_logs")
}
