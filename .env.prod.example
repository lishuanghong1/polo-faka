# =========================================================
# Polo Faka · 生产环境变量模板
# 部署前 cp .env.prod.example .env.prod 并修改下面所有 CHANGEME
# =========================================================

# ── 域名 ──────────────────────────────────────────────
# Caddy 用它申请 HTTPS 证书。需要先把 DNS A 记录解析到服务器 IP
DOMAIN=example.com

# ── MySQL ────────────────────────────────────────────
# 用 openssl rand -hex 24 生成
MYSQL_ROOT_PASSWORD=CHANGEME_root_strong_password
MYSQL_PASSWORD=CHANGEME_app_strong_password

# ── Redis ────────────────────────────────────────────
REDIS_PASSWORD=CHANGEME_redis_strong_password

# ── JWT / 加密 ───────────────────────────────────────
# 都要 ≥ 32 字节随机字符串。生成命令：openssl rand -hex 32
JWT_SECRET=CHANGEME_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# 号池 / 支付宝私钥 等敏感数据 AES-256-GCM 加密密钥
POOL_ENCRYPTION_KEY=CHANGEME_pool_encryption_key_32_chars

# ── 默认管理员 ────────────────────────────────────────
# 首次启动会自动创建（已存在则跳过）
ADMIN_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=CHANGEME_admin_login_after_first_login_then_modify

# ── CORS ─────────────────────────────────────────────
# 前后端同源时（推荐）填你的站点 URL
CORS_ORIGINS=https://example.com

# ── 管理员 IP 白名单（强烈建议生产配置）────────────────
# 留空 = 不限制，仅靠 JWT + ADMIN 角色
# 例：办公室固定公网 IP + 自己的家庭宽带
# ADMIN_IP_ALLOWLIST=1.2.3.4,4.5.6.0/24
ADMIN_IP_ALLOWLIST=

# ── 支付宝（可选）─────────────────────────────────────
# 先用 ALIPAY_ENABLED=false 部署上线，之后在后台「站点设置」里填
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
# 支付宝异步通知/同步返回需要的公网前缀。例 https://example.com
ALIPAY_NOTIFY_BASE_URL=https://example.com
ALIPAY_SANDBOX=false
ALIPAY_SIGN_TYPE=RSA2
