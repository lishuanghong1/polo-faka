# =========================================================
# Polo Faka · 生产环境变量模板
# 部署前 cp .env.prod.example .env.prod 并修改下面所有 CHANGEME
# =========================================================

# ── 域名 ──────────────────────────────────────────────
# Caddy 用它申请 HTTPS 证书。需要先把 DNS A 记录解析到服务器 IP
DOMAIN=example.com

# ── MySQL ────────────────────────────────────────────
# 用 openssl rand -hex 24 生成
MYSQL_ROOT_PASSWORD=CHANGEME_root_strong_password
MYSQL_PASSWORD=CHANGEME_app_strong_password

# ── Redis ────────────────────────────────────────────
REDIS_PASSWORD=CHANGEME_redis_strong_password

# ── JWT / 加密 ───────────────────────────────────────
# 都要 ≥ 32 字节随机字符串。生成命令：openssl rand -hex 32
JWT_SECRET=CHANGEME_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# 号池 / 支付宝私钥 等敏感数据 AES-256-GCM 加密密钥
POOL_ENCRYPTION_KEY=CHANGEME_pool_encryption_key_32_chars

# ── 默认管理员 ────────────────────────────────────────
# 首次启动会自动创建（已存在则跳过）
ADMIN_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=CHANGEME_admin_login_after_first_login_then_modify

# ── CORS ─────────────────────────────────────────────
# 前后端同源时（推荐）填你的站点 URL
CORS_ORIGINS=https://example.com

# ── 管理员 IP 白名单（强烈建议生产配置）────────────────
# 留空 = 不限制，仅靠 JWT + ADMIN 角色
# 例：办公室固定公网 IP + 自己的家庭宽带
# ADMIN_IP_ALLOWLIST=1.2.3.4,4.5.6.0/24
ADMIN_IP_ALLOWLIST=

# ── Mock 支付（生产必须 false！）────────────────────────
# true = 暴露 /api/orders/:no/mock-pay 直接把订单标为已支付，仅本地测试用
ENABLE_MOCK_PAY=false

# ── Cursorforge 代理 OpenAPI 接码 ────────────────────
# 推荐留空，去后台「站点设置 → 接码接口」配；env 非空才覆盖。
# 鉴权：HMAC-SHA256；agent_secret 仅后端持有用于签名，不出现在请求里。
# ⚠ cursorforgeai 后台必须给该 key 配置 IP 白名单（生产服务器固定出口 IP）。
EMAIL_CODE_ENABLED=
EMAIL_CODE_API_BASE=
EMAIL_CODE_AGENT_KEY=
EMAIL_CODE_AGENT_SECRET=
EMAIL_CODE_TIMEOUT_MS=

# ── 支付宝 ────────────────────────────────────────────
# 推荐方式：这里全部留空 → 部署完成后登录后台「站点设置 → 支付宝」配置
# 私钥/公钥在后台填会用 AES-GCM 加密入库；写在 .env 里只是明文文本。
#
# 如果你确实想用 env 方式（CI/自动化场景），把下面的值都填上即可，
# 任何一项「留空」时都会自动 fallback 到后台的数据库设置。
ALIPAY_ENABLED=
ALIPAY_SANDBOX=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SIGN_TYPE=
ALIPAY_SELLER_ID=
# 支付宝异步通知 / 同步返回需要的公网前缀（不带尾部斜杠）。例：https://example.com
# 留空时使用后台「公网回调 Base URL」字段。
ALIPAY_NOTIFY_BASE_URL=
